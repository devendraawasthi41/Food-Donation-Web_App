<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>About Us | Food Aid</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- Bootstrap + Font Awesome -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="stylesheet" href="/assets/css/sidebar.css">
</head>
<body>

<!-- Hero Section -->
<section class="hero-section text-center py-5 bg-light">
  <div class="container">
    <img src="/assets/images/logo.jpg" alt="Food Aid Logo" class="mb-3" style="max-width: 150px;">
    <h1 class="display-5">About Food Aid</h1>
    <p class="lead">Together, we can make sure no food goes to waste and no one goes hungry.</p>
  </div>
</section>

<!-- Mission & Vision Section -->
<section class="container mt-5">
  <div class="row">
    <div class="col-lg-6">
      <h2>Our Mission</h2>
      <p>At Food Aid, we believe in creating a hunger-free world by connecting generous donors with communities in need. We are dedicated to reducing food waste and ensuring that surplus food reaches those who need it most.</p>
    </div>
    <div class="col-lg-6">
      <h2>Our Vision</h2>
      <p>We envision a future where every meal finds a home, and no one is left hungry. Through innovation, compassion, and collaboration, we aim to end hunger and promote food security globally.</p>
    </div>
  </div>
</section>

<!-- Impact Section -->
<section class="container mt-5 text-center">
  <h2>Our Impact</h2>
  <div class="row">
    <div class="col-md-4">
      <h3>10,000+</h3>
      <p>Meals Donated</p>
    </div>
    <div class="col-md-4">
      <h3>50+</h3>
      <p>Communities Supported</p>
    </div>
    <div class="col-md-4">
      <h3>500+</h3>
      <p>Active Volunteers</p>
    </div>
  </div>
</section>

<!-- Team Section -->
<section class="container mt-5">
  <h2 class="text-center mb-4">Meet Our Team</h2>
  <div class="row gy-4">
    <div class="col-md-4 text-center">
      <img src="https://randomuser.me/api/portraits/men/11.jpg" alt="Rajesh Kumar" class="rounded-circle mb-2" width="120">
      <h5>Rajesh Kumar</h5>
      <p class="text-muted">Founder & Director</p>
    </div>
    <div class="col-md-4 text-center">
      <img src="https://randomuser.me/api/portraits/women/22.jpg" alt="Sneha Singh" class="rounded-circle mb-2" width="120">
      <h5>Sneha Singh</h5>
      <p class="text-muted">Operations Manager</p>
    </div>
    <div class="col-md-4 text-center">
      <img src="https://randomuser.me/api/portraits/men/33.jpg" alt="Amit Sharma" class="rounded-circle mb-2" width="120">
      <h5>Amit Sharma</h5>
      <p class="text-muted">Community Outreach</p>
    </div>
  </div>
</section>

<h4 class="mb-4 text-center text-secondary">Gallery</h4>
  <div class="row g-4">
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card shadow-sm h-100">
        <img src="/assets/images/th (1).jpeg" class="card-img-top rounded" alt="Food 1">
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card shadow-sm h-100">
        <img src="/assets/images/th.jpeg" class="card-img-top rounded" alt="Food 2">
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card shadow-sm h-100">
        <img src="/assets/images/img7.jpg" class="card-img-top rounded" alt="Food 3">
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card shadow-sm h-100">
        <img src="/assets/images/ig.jpg" class="card-img-top rounded" alt="Food 4">
      </div>
    </div>
<!-- Footer -->
<footer class="bg-light py-3">
  <div class="container text-center">
    <p class="mb-1">&copy; 2025 Food Aid | Built with 💚 for a better world</p>
    <div class="social-links">
      <a href="#" class="me-3"><i class="fab fa-facebook fa-lg"></i></a>
      <a href="#" class="me-3"><i class="fab fa-instagram fa-lg"></i></a>
      <a href="#" class="me-3"><i class="fab fa-twitter fa-lg"></i></a>
      <a href="#"><i class="fab fa-linkedin fa-lg"></i></a>
    </div>
  </div>
</footer>


<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/assets/js/script.js"></script>
</body>
</html>
