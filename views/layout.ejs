	<!-- Contact Section -->
<section id="contact" class="contact section py-4" style="background: linear-gradient(135deg, #0f2027, #203a43, #2c5364); color: #fff;">
  <div class="container">
    <div class="section-title text-center mb-4">
      <h2 style="color: #00ff99;">Contact Us</h2>
      <p>Have questions? <span style="color: #00ff99;">We’re here to help</span></p>
    </div>
    <div class="row gy-4">
      <div class="col-lg-4">
        <div class="info-item mb-4">
          <i class="fas fa-map-marker-alt mb-2" style="color: #00ff99;"></i>
          <h5>Address</h5>
          <p>00 Shee Nagar Colony, Lucknow, Uttar Pradesh</p>
        </div>
        <div class="info-item mb-4">
          <i class="fas fa-phone mb-2" style="color: #00ff99;"></i>
          <h5>Phone</h5>
          <p>+91 70806 81734</p>
        </div>
        <div class="info-item">
          <i class="fas fa-envelope mb-2" style="color: #00ff99;"></i>
          <h5>Email</h5>
          <p>deva@example.com</p>
        </div>
      </div>
  <div class="col-lg-8">
    <form id="contactForm" class="php-email-form">
        <div class="row gy-3">
            <div class="col-md-6">
                <input type="text" name="name" class="form-control" placeholder="Your Name" required>
            </div>
            <div class="col-md-6">
                <input type="email" name="email" class="form-control" placeholder="Your Email" required>
            </div>
            <div class="col-md-12">
                <input type="text" name="subject" class="form-control" placeholder="Subject" required>
            </div>
            <div class="col-md-12">
                <textarea name="message" class="form-control" rows="5" placeholder="Message" required></textarea>
            </div>
            <div class="col-md-12 text-center">
                <button type="submit" class="btn btn-primary px-4" style="background-color: #00ff99; border: none;">Send Message</button>
            </div>
        </div>
    </form>
    <div id="formResult" class="mt-3" style="display: none; color: #00ff99; text-align: center;">
        Thank you! Your message has been sent.
    </div>
</div>

<script>
document.getElementById('contactForm').addEventListener('submit', function(e) {
    e.preventDefault();  // stop the form from refreshing the page

    // Get form data
    const formData = new FormData(this);
    const name = formData.get('name');
    const email = formData.get('email');
    const subject = formData.get('subject');
    const message = formData.get('message');

    // For now, just log or show a success message
    console.log("Form submitted:", { name, email, subject, message });

    // Show success message
    document.getElementById('formResult').style.display = 'block';

    // Optionally reset the form
    this.reset();
});
</script>


