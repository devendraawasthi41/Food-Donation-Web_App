<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Food Aid</title>
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="/assets/css/sidebar.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-dark p-0">
            <div class="container-fluid">
                <a class="navbar-brand text-white d-flex align-items-center" href="/">
                    <img src="/assets/images/logo.jpg" alt="Food Aid Logo" class="d-inline-block align-text-top" style="height: 40px; width: 40px; margin-right: 8px;">
                    Food Aid
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span><i class="fas fa-bars text-white"></i></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav ms-auto me-3">
                    <li class="nav-item"><a class="nav-link text-white" href="/">Home</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/home/about-us">About Us</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/home/mission">Our Mission</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/home/contact-us">Contact Us</a></li>
                        <% if (currentUser) { %>
                            <li class="nav-item">
                                <span class="nav-link text-white user-icon"><%= currentUser.firstName[0] %></span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/auth/logout" id="logout-btn">Logout</a>
                            </li>
                        <% } else { %>
                            <li class="nav-item"><a class="nav-link text-white" href="/auth/login">Login</a></li>
                            <li class="nav-item"><a class="nav-link text-white" href="/auth/signup">Signup</a></li>
                        <% } %>
                    </ul>
                </div>
            </div>
            
        </nav>
        
    </header>

   

    <script src="/assets/js/script.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

